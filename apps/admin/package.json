    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "autoprefixer": "10.4.21",
    "next": "15.5.15",
    "postcss": "8.5.6",
    "react": "19.1.4",
    "react-dom": "19.1.4",
    "superjson": "^2.2.2",
    "tailwindcss": "3.4.17"
  },
  "devDependencies": {
