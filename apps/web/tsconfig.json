{
  "extends": "@pathfinder/config/typescript/nextjs.json",
  "compilerOptions": {
    "types": ["node"],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
