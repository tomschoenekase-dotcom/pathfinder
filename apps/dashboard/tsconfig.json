{
  "extends": "@pathfinder/config/typescript/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "node"
    ],
    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
