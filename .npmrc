# Network settings — prevents pnpm install from hanging indefinitely
# in CI and sandboxed environments (e.g. Codex)
network-timeout=30000
fetch-retries=2
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=20000

# Use the local store; avoids contention in parallel CI runs
prefer-frozen-lockfile=true

# Hoist Prisma to root node_modules so bundled workers can resolve it at runtime
public-hoist-pattern[]=@prisma/client
public-hoist-pattern[]=.prisma
